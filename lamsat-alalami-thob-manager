package com.lamsat.tailormanager;

import android.os.Bundle;
import androidx.annotation.NonNull;
import androidx.appcompat.app.AppCompatActivity;
import androidx.fragment.app.Fragment;
import com.google.android.material.bottomnavigation.BottomNavigationView;

public class MainActivity extends AppCompatActivity {

    BottomNavigationView bottomNavigationView;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        bottomNavigationView = findViewById(R.id.bottom_navigation);

        // الافتراضي: InventoryFragment
        getSupportFragmentManager().beginTransaction().replace(R.id.fragment_container, new InventoryFragment()).commit();

        bottomNavigationView.setOnItemSelectedListener(item -> {
            Fragment selectedFragment = null;
            switch(item.getItemId()){
                case R.id.nav_inventory:
                    selectedFragment = new InventoryFragment();
                    break;
                case R.id.nav_sales:
                    selectedFragment = new SalesFragment();
                    break;
                case R.id.nav_workers:
                    selectedFragment = new WorkersFragment();
                    break;
                case R.id.nav_reservations:
                    selectedFragment = new ReservationsFragment();
                    break;
                case R.id.nav_tailoring:
                    selectedFragment = new TailoringFragment();
                    break;
                case R.id.nav_alterations:
                    selectedFragment = new AlterationsFragment();
                    break;
                case R.id.nav_debts:
                    selectedFragment = new DebtsFragment();
                    break;
                case R.id.nav_suppliers:
                    selectedFragment = new SuppliersFragment();
                    break;
                case R.id.nav_settings:
                    selectedFragment = new SettingsFragment();
                    break;
            }

            getSupportFragmentManager().beginTransaction().replace(R.id.fragment_container, selectedFragment).commit();
            return true;
        });
    }
}package com.lamsat.tailormanager;

import android.content.Context;
import android.database.sqlite.SQLiteDatabase;
import android.database.sqlite.SQLiteOpenHelper;

public class SQLiteHelper extends SQLiteOpenHelper {

    private static final String DB_NAME = "TailorManager.db";
    private static final int DB_VERSION = 1;

    public SQLiteHelper(Context context){
        super(context, DB_NAME, null, DB_VERSION);
    }

    @Override
    public void onCreate(SQLiteDatabase db) {
        // جدول المخزون
        db.execSQL("CREATE TABLE inventory(id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, color TEXT, length INTEGER, width INTEGER, fabric TEXT, quantity INTEGER, price REAL, purchase_price REAL)");

        // جدول المبيعات
        db.execSQL("CREATE TABLE sales(id INTEGER PRIMARY KEY AUTOINCREMENT, inventory_id INTEGER, quantity INTEGER, price REAL, discount REAL, final_price REAL, received REAL, date TEXT, worker_name TEXT)");

        // جدول العمال
        db.execSQL("CREATE TABLE workers(id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, phone TEXT, total_sales REAL, deductions REAL, withdrawals REAL)");

        // جدول الحجوزات
        db.execSQL("CREATE TABLE reservations(id INTEGER PRIMARY KEY AUTOINCREMENT, client_name TEXT, phone TEXT, quantity INTEGER, color TEXT, length INTEGER, width INTEGER, price REAL, delivered REAL, remaining REAL)");

        // جدول طلب التفصيل
        db.execSQL("CREATE TABLE tailoring(id INTEGER PRIMARY KEY AUTOINCREMENT, client_name TEXT, phone TEXT, length INTEGER, width INTEGER, neck INTEGER, sleeve INTEGER, fabric TEXT, color TEXT, pockets TEXT, buttons TEXT, zipper TEXT, price REAL, date TEXT)");

        // جدول التعديلات
        db.execSQL("CREATE TABLE alterations(id INTEGER PRIMARY KEY AUTOINCREMENT, client_name TEXT, phone TEXT, old_length INTEGER, old_width INTEGER, new_length INTEGER, new_width INTEGER, price REAL, status TEXT)");

        // جدول المديونية
        db.execSQL("CREATE TABLE debts(id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, phone TEXT, amount REAL, remaining REAL, type TEXT)");

        // جدول الموردين
        db.execSQL("CREATE TABLE suppliers(id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, phone TEXT, fabric_type TEXT, supplies TEXT)");
    }

    @Override
    public void onUpgrade(SQLiteDatabase db, int oldVersion, int newVersion) {
        // تحديثات مستقبلية
        db.execSQL("DROP TABLE IF EXISTS inventory");
        db.execSQL("DROP TABLE IF EXISTS sales");
        db.execSQL("DROP TABLE IF EXISTS workers");
        db.execSQL("DROP TABLE IF EXISTS reservations");
        db.execSQL("DROP TABLE IF EXISTS tailoring");
        db.execSQL("DROP TABLE IF EXISTS alterations");
        db.execSQL("DROP TABLE IF EXISTS debts");
        db.execSQL("DROP TABLE IF EXISTS suppliers");
        onCreate(db);
    }
